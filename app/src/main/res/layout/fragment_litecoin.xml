<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Litecoin — MWEB"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Sync state -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sync state"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcSyncState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:layout_marginBottom="8dp" />

        <!-- Last block -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last block"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcLastBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:layout_marginBottom="8dp" />

        <!-- Balance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Balance"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:layout_marginBottom="8dp" />

        <!-- MWEB balance -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MWEB balance"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcMwebBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:layout_marginBottom="16dp" />

        <!-- LTC receive address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LTC receive address (BIP84)"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcReceiveAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textIsSelectable="true"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/ltcCopyReceive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy"
            android:layout_marginBottom="16dp" />

        <!-- MWEB address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MWEB address (ltcmweb1…)"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/ltcMwebAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textIsSelectable="true"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/ltcCopyMweb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy"
            android:layout_marginBottom="24dp" />

        <!-- MWEB Peg-Out -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MWEB Peg-Out (MWEB → LTC)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/ltcPegOutAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Destination LTC address"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/ltcPegOutAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Amount (satoshis)"
            android:inputType="number"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/ltcPegOutFeeRate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fee rate (sat/byte, default 10)"
            android:inputType="number"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated fee: "
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ltcPegOutFeeEstimate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/ltcButtonEstimateFee"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Estimate Fee"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/ltcButtonPegOut"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Send (Peg-Out)" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="16dp" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/ltcButtonStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/ltcButtonStop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Stop"
                android:enabled="false"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/ltcButtonClear"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>